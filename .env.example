# ── Core ─────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
ANTHROPIC_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Cloudflare R2 (rendered MP4s + manual inbox) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RENDERED=reels-rendered
R2_BUCKET_INBOX=reels-inbox
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.example.com

# ── Content source APIs ──────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Per-page platform credentials ────────────────────────────────────────────
# Suffix = `envKey` from src/config/channels.js. Multiple channels can share
# one envKey when they publish to the same FB Page.

# Page 1: Wildlife Daily (channels: wildlife/factual/EN, wildlife/listicle/EN)
FB_PAGE_ID_WILDLIFE_DAILY=
FB_ACCESS_TOKEN_WILDLIFE_DAILY=
IG_USER_ID_WILDLIFE_DAILY=
IG_ACCESS_TOKEN_WILDLIFE_DAILY=
YT_CLIENT_ID_WILDLIFE_DAILY=
YT_CLIENT_SECRET_WILDLIFE_DAILY=
YT_REFRESH_TOKEN_WILDLIFE_DAILY=
TT_CLIENT_KEY_WILDLIFE_DAILY=
TT_CLIENT_SECRET_WILDLIFE_DAILY=
TT_ACCESS_TOKEN_WILDLIFE_DAILY=

# Page 2: Wild Cinema (channels: wildlife/cinematic/EN, wildlife/silent/EN)
FB_PAGE_ID_WILD_CINEMA=
FB_ACCESS_TOKEN_WILD_CINEMA=
IG_USER_ID_WILD_CINEMA=
IG_ACCESS_TOKEN_WILD_CINEMA=
YT_CLIENT_ID_WILD_CINEMA=
YT_CLIENT_SECRET_WILD_CINEMA=
YT_REFRESH_TOKEN_WILD_CINEMA=
TT_CLIENT_KEY_WILD_CINEMA=
TT_CLIENT_SECRET_WILD_CINEMA=
TT_ACCESS_TOKEN_WILD_CINEMA=
