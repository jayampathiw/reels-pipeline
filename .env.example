# ── Core ─────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
ANTHROPIC_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Cloudflare R2 (rendered MP4s + manual inbox) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RENDERED=reels-rendered
R2_BUCKET_INBOX=reels-inbox
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.example.com

# ── Content source APIs ──────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Per-page platform credentials ────────────────────────────────────────────
# Suffix = `envKey` from src/config/channels.js. Multiple channels can share
# one envKey when they publish to the same FB Page.

# Page 1: NaturePulse (channels: wildlife/factual/EN, wildlife/listicle/EN)
FB_PAGE_ID_NATURE_PULSE=
FB_ACCESS_TOKEN_NATURE_PULSE=
IG_USER_ID_NATURE_PULSE=
IG_ACCESS_TOKEN_NATURE_PULSE=
YT_CLIENT_ID_NATURE_PULSE=
YT_CLIENT_SECRET_NATURE_PULSE=
YT_REFRESH_TOKEN_NATURE_PULSE=
TT_CLIENT_KEY_NATURE_PULSE=
TT_CLIENT_SECRET_NATURE_PULSE=
TT_ACCESS_TOKEN_NATURE_PULSE=

# Page 2: NatureFrame (channels: wildlife/cinematic/EN, wildlife/silent/EN)
FB_PAGE_ID_NATURE_FRAME=
FB_ACCESS_TOKEN_NATURE_FRAME=
IG_USER_ID_NATURE_FRAME=
IG_ACCESS_TOKEN_NATURE_FRAME=
YT_CLIENT_ID_NATURE_FRAME=
YT_CLIENT_SECRET_NATURE_FRAME=
YT_REFRESH_TOKEN_NATURE_FRAME=
TT_CLIENT_KEY_NATURE_FRAME=
TT_CLIENT_SECRET_NATURE_FRAME=
TT_ACCESS_TOKEN_NATURE_FRAME=

# Page 3: France Aujourd'hui (channel: culture/silent/FR) — shared with facebook-news-pipeline
FB_PAGE_ID_FR=
FB_ACCESS_TOKEN_FR=

# Page 4: Vivere in Italia (channel: culture/silent/IT) — shared with facebook-news-pipeline
FB_PAGE_ID_IT=
FB_ACCESS_TOKEN_IT=
